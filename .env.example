# ============================================================
# Backup Failure Triage Agent
# Environment Configuration
# ============================================================

# ============================================================
# Google Gemini API
# Get your API key from:
# https://aistudio.google.com/app/apikey
# ============================================================

GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# Application
# ============================================================

APP_NAME=Backup Failure Triage Agent
APP_VERSION=1.0.0
APP_ENV=development

# Logging Level
LOG_LEVEL=INFO

# ============================================================
# SQLite Database
# ============================================================

DATABASE_PATH=memory/incidents.db

# ============================================================
# Report Output
# ============================================================

REPORT_OUTPUT_DIR=output/reports

SCRIPT_OUTPUT_DIR=output/scripts

# ============================================================
# Sample Log Directory
# ============================================================

SAMPLE_LOG_DIR=data/sample_logs

# ============================================================
# MCP Server
# ============================================================

MCP_HOST=127.0.0.1
MCP_PORT=8001

# ============================================================
# Security
# ============================================================

ENABLE_LOG_SANITIZATION=true

ALLOW_DESTRUCTIVE_COMMANDS=false

REQUIRE_HUMAN_APPROVAL=true

# ============================================================
# Confidence Threshold
# ============================================================

MIN_CONFIDENCE=0.70

# ============================================================
# CLI
# ============================================================

DEFAULT_REPORT_FORMAT=markdown

DEFAULT_SCRIPT_TYPE=powershell

# ============================================================
# Future Features (Reserved)
# ============================================================

ENABLE_MEMORY=true

ENABLE_VECTOR_SEARCH=false

ENABLE_PDF_REPORTS=true

ENABLE_JSON_EXPORT=true